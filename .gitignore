# Private data — never commit (AGENTS.md "Safety")
pb_data/
*.db
*.db-shm
*.db-wal

# Models and inference libraries (downloaded data, not source)
*.gguf
models/
libs/

# Build artifacts
/balaur
/balaur.exe
dist/
.cache/
tmp/

# Delve debug binaries (random suffix per `dlv debug` / VS Code session)
__debug_bin*

# Local environment
.env
.env.*

# Claude Code: ignore personal/local state (settings.local.json, locks,
# worktrees) but track shared project config so the setup syncs across machines.
.claude/*
!.claude/settings.json
!.claude/skills

# Browser-in-the-loop debug artifacts (Playwright snapshots, scratch screenshots)
.playwright-mcp/
/*.png
