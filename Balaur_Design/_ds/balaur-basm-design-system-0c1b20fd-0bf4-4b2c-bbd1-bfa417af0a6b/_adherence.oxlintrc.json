{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chat/**",
              "components/core/**",
              "components/knowledge/**",
              "components/navigation/**",
              "ui_kits/balaur/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Jersey 15|Piazzolla|Pixelify Sans|Silkscreen|Work Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Jersey 15, Piazzolla, Pixelify Sans, Silkscreen, Work Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|kind|size|state|alt|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, kind, size, state, alt."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:balaur|soul)$/]",
        "message": "<Avatar> kind must be one of 'balaur' | 'soul'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:idle|thinking|working)$/]",
        "message": "<Avatar> state must be one of 'idle' | 'thinking' | 'working'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|children|onClick|disabled|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, children, onClick, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|wood)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'wood'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm)$/]",
        "message": "<Button> size must be one of 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|sendLabel|above|onSend|fixed|rows|key|ref|className|style|children)$/]",
        "message": "<ChatBar> doesn't accept that prop. Declared props: placeholder, sendLabel, above, onSend, fixed, rows."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|who|avatarSrc|pending|reveal|origin|children|key|ref|className|style|children)$/]",
        "message": "<ChatMessage> doesn't accept that prop. Declared props: role, who, avatarSrc, pending, reveal, origin, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|balaur|tool)$/]",
        "message": "<ChatMessage> role must be one of 'user' | 'balaur' | 'tool'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DialogueChoice'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|onPick|key|ref|className|style|children)$/]",
        "message": "<DialogueChoice> doesn't accept that prop. Declared props: label, hint, onPick."
      },
      {
        "selector": "JSXOpeningElement[name.name='FolkBand'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<FolkBand> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KnowledgeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|status|title|body|whenToUse|importance|usedCount|onApprove|onDismiss|onArchive|onRestore|key|ref|className|style|children)$/]",
        "message": "<KnowledgeCard> doesn't accept that prop. Declared props: kind, status, title, body, whenToUse, importance, usedCount, onApprove, onDismiss, onArchive, onRestore."
      },
      {
        "selector": "JSXOpeningElement[name.name='KnowledgeCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:proposed|active|archived)$/]",
        "message": "<KnowledgeCard> status must be one of 'proposed' | 'active' | 'archived'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageDraft'] > JSXAttribute > JSXIdentifier[name!=/^(?:who|avatarSrc|placeholder|sendLabel|onSend|key|ref|className|style|children)$/]",
        "message": "<MessageDraft> doesn't accept that prop. Declared props: who, avatarSrc, placeholder, sendLabel, onSend."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pips'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|max|title|key|ref|className|style|children)$/]",
        "message": "<Pips> doesn't accept that prop. Declared props: level, max, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:style|key|ref|className|style|children)$/]",
        "message": "<Stitch> doesn't accept that prop. Declared props: style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|active|onSelect|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: items, active, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|status|dueLine|overdue|recurLine|notes|onDone|onSnooze|onDrop|key|ref|className|style|children)$/]",
        "message": "<TaskCard> doesn't accept that prop. Declared props: title, status, dueLine, overdue, recurLine, notes, onDone, onSnooze, onDrop."
      },
      {
        "selector": "JSXOpeningElement[name.name='TaskCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|done|dropped)$/]",
        "message": "<TaskCard> status must be one of 'open' | 'done' | 'dropped'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:tool|icon|glyph|children|key|ref|className|style|children)$/]",
        "message": "<ToolRow> doesn't accept that prop. Declared props: tool, icon, glyph, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Topbar'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|crestSrc|links|active|onNavigate|onToggleTheme|themeGlyph|key|ref|className|style|children)$/]",
        "message": "<Topbar> doesn't accept that prop. Declared props: brand, crestSrc, links, active, onNavigate, onToggleTheme, themeGlyph."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
