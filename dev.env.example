# Local dev environment for `make dev` — copy to dev.env (gitignored) and fill in.
#
#   cp dev.env.example dev.env   &&   edit dev.env
#
# `make dev` sources dev.env, so any KEY=value here is exported to the dev
# server. It is NEVER committed (see .gitignore) and NEVER read by prod.

# Mistral API key. When set, the dev server auto-registers the curated Mistral
# cloud preset (mistral-small-latest) and selects it as the active model, so
# chat turns work during local testing without the Models page. Get one at
# https://console.mistral.ai/api-keys. Leave unset to keep inference local.
BALAUR_MISTRAL_KEY=
