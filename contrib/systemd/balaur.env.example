# Optional Balaur service environment.
# Copy to ~/.config/balaur/env and keep it private.

# Service defaults:
# BALAUR_HTTP=127.0.0.1:8090
# BALAUR_DATA_DIR=/home/you/.local/share/balaur/pb_data

# Local GGUF model through Kronk:
# BALAUR_CHAT_MODEL=/path/to/model.gguf
# BALAUR_EMBED_MODEL=/path/to/embedding.gguf

# OpenAI-compatible endpoint:
# BALAUR_REMOTE_URL=http://127.0.0.1:11434/v1
# BALAUR_REMOTE_MODEL=qwen
# BALAUR_REMOTE_API_KEY=

# Self-development tools, disabled by default:
# BALAUR_OS_ACCESS=1
# BALAUR_SOURCE=/path/to/balaur
# BALAUR_MAX_STEPS=24

# Optional background jobs:
# BALAUR_RECAP=0
# BALAUR_NUDGE=0
# BALAUR_BRIEFING=0
# BALAUR_BRIEFING_HOUR=9

# Optional extension directory override:
# BALAUR_EXT_DIR=/path/to/pb_extensions
